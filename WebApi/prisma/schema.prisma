generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PROFESSOR
  ALUNO
  ADMIN
}

enum StatusUsuario {
  ATIVO
  INATIVO
}

enum ResultadoResposta {
  CERTO
  ERRADO
}

enum Prioridade {
  ALTA
  MEDIA
  BAIXA
}

model Instituicao {
  id          Int      @id @default(autoincrement())
  nome        String
  cep         String
  rua         String
  numero      String
  bairro      String
  cidade      String
  estado      String

  usuarios   UsuarioInstituicao[]
  salas       Sala[]

  created_at  DateTime @default(now())
}

model Usuario {
  id              Int      @id @default(autoincrement())
  nome            String
  email           String   @unique
  senha           String
  role            Role
  status          StatusUsuario @default(ATIVO)
  data_nascimento DateTime?
  celular         String?

  instituicoes    UsuarioInstituicao[]

  salas_criadas   Sala[] @relation("ProfessorSalas")
  relatorios      RelatorioAluno[]

  created_at      DateTime @default(now())
  notas           Nota[]
}

model UsuarioInstituicao {
  id             Int @id @default(autoincrement())

  usuarioId      Int
  instituicaoId  Int

  usuario        Usuario     @relation(fields: [usuarioId], references: [id])
  instituicao    Instituicao @relation(fields: [instituicaoId], references: [id])

  @@unique([usuarioId, instituicaoId])
}

model Sala {
  id                   Int      @id @default(autoincrement())
  nome                 String
  descricao            String?
  turma                String

  ativa                Boolean  @default(true)

  permitir_tentativas  Boolean  @default(false)
  limite_tentativas    Int?

  instituicao_id       Int
  professor_id         Int

  instituicao          Instituicao @relation(fields: [instituicao_id], references: [id])
  professor            Usuario     @relation("ProfessorSalas", fields: [professor_id], references: [id])

  flashcards           Flashcard[]
  relatorio_geral      RelatorioGeral?

  created_at           DateTime @default(now())
}

model Flashcard {
  id          Int      @id @default(autoincrement())
  pergunta    String
  resposta    String
  imagem_url  String?
  ativo       Boolean  @default(true)

  sala_id     Int
  sala        Sala @relation(fields: [sala_id], references: [id])

  respostas   RespostaFlashcard[]

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

model RelatorioGeral {
  id          Int @id @default(autoincrement())
  sala_id     Int @unique

  sala        Sala @relation(fields: [sala_id], references: [id])
  relatorios  RelatorioAluno[]

  created_at  DateTime @default(now())
}

model RelatorioAluno {
  id                 Int @id @default(autoincrement())
  relatorio_geral_id Int
  aluno_id           Int
  tentativa_numero   Int
  total_flashcards   Int
  total_acertos      Int

  relatorio_geral    RelatorioGeral @relation(fields: [relatorio_geral_id], references: [id])
  aluno              Usuario        @relation(fields: [aluno_id], references: [id])
  respostas           RespostaFlashcard[]

  created_at          DateTime @default(now())
}

model RespostaFlashcard {
  id                  Int @id @default(autoincrement())
  relatorio_aluno_id  Int
  flashcard_id        Int
  resposta            ResultadoResposta

  relatorio_aluno     RelatorioAluno @relation(fields: [relatorio_aluno_id], references: [id])
  flashcard           Flashcard      @relation(fields: [flashcard_id], references: [id])

  created_at          DateTime @default(now())
}

model Nota {
  id        Int       @id @default(autoincrement())
  titulo    String
  descricao String?
  prioridade Prioridade
  ativo     Boolean   @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  usuario_id Int
  usuario    Usuario  @relation(fields: [usuario_id], references: [id])
}

model RecuperaSenha {
  id         Int      @id @default(autoincrement())
  email      String
  codigo     String
  expira_em  DateTime
  usado      Boolean  @default(false)

  created_at DateTime @default(now())
}