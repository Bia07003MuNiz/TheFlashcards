{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "noEmit": true,
        "moduleResolution": "node",
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "esModuleInterop": true,
        "baseUrl": "./src",
        "paths": {
            "@decorators/*": [
                "utils/decorators/*"
            ],
            "@modules/*": [
                "modules/*"
            ],
            "@database/*": [
                "database/*"
            ],
            "@shared/*": [
                "shared/*"
            ],
            "@errors/*": [
                "errors/*"
            ],
            "@dtos/*": [
                "utils/dtos/*"
            ],
            "@customTypes/*": [
                "utils/types/*"
            ],
            "@abstracts/*": [
                "utils/abstracts/*"
            ],
            "@config/*": [
                "config/*"
            ]
        }
    }
}